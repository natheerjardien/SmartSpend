<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#0D000000"
    app:cardCornerRadius="12dp"
    android:padding="@dimen/screen_margin">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRowDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-03-17"
            android:textColor="#3F51B5"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvRowCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvRowDate"
            android:layout_marginTop="4dp"
            android:text="Weekly Groceries"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRowAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="R 1,200.00"
            android:textColor="#2196F3"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivHasPhoto"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:layout_toStartOf="@id/tvRowAmount"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#2196F3" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>