<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A000000"
    android:padding="@dimen/screen_margin" >

    <TextView
        android:id="@+id/tvLogHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TRANSACTION LOG"
        android:textColor="#2196F3"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnFilter"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:backgroundTint="#2196F3"
        android:paddingHorizontal="16dp"
        android:text="FILTER"
        android:textColor="#0F0F1E"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/tvLogHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvLogHeader" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTransactionLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintTop_toBottomOf="@id/tvLogHeader" />

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@drawable/rounded_card"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Home"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnNavEntry"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Expense"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnNavBudget"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Budget"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnNavAnalytic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Stats"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#2196F3" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>