<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FINANCIAL ANALYTICS"
            android:textColor="#00FFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Budget Progress"
            android:textColor="#BB86FC"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/pbMonthlyGoal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:progress="75"
            android:progressTint="#00FFFF"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="75% of Max Goal Reached"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spending by Category"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Groceries"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="R 3,200.00"
                android:textColor="#00FFFF"
                android:textStyle="bold"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entertainment"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="R 1,500.00"
                android:textColor="#00FFFF"
                android:textStyle="bold"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transport"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="R 850.00"
                android:textColor="#00FFFF"
                android:textStyle="bold"/>
        </RelativeLayout>

        <Button
            android:id="@+id/btnViewLog"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#00FFFF"
            android:text="VIEW FULL TRANSACTION LOG"
            android:textColor="#0F0F1E"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1A1A2E"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button android:id="@+id/btnNavHome" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Home" android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnNavEntry" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Add Expense" android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnNavBudget" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Budget" android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnNavAnalytic" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Analytic" android:backgroundTint="@android:color/transparent" android:textColor="#00FFFF"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>