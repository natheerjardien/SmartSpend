<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A000000"
    android:padding="@dimen/screen_margin" >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/tvBudgetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="BUDGET GOALS"
                android:textColor="#2196F3"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Set Minimum Monthly Goal"
                android:textColor="#3F51B5"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etMinGoal"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:backgroundTint="#3F51B5"
                android:hint="e.g. R 1,500.00"
                android:inputType="numberDecimal"
                android:textColor="#000000"
                android:textColorHint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Set Maximum Monthly Goal"
                android:textColor="#3F51B5"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etMaxGoal"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:backgroundTint="#BB86FC"
                android:hint="e.g. R 10,000.00"
                android:inputType="numberDecimal"
                android:textColor="#000000"
                android:textColorHint="#000000" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#1A1A2E" />



            <Button
                android:id="@+id/btnSaveBudget"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:backgroundTint="#2196F3"
                android:text="SAVE BUDGET PLAN"
                android:textColor="#0F0F1E"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@drawable/rounded_card"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Home"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnNavEntry"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Expense"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnNavBudget"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Budget"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#2196F3" />

        <Button
            android:id="@+id/btnNavAnalytic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Stats"
            android:textAllCaps="false"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textSize="11sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>