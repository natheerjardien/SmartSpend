<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A000000"
    android:padding="@dimen/screen_margin" >

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Navigate back to Home Page"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#2196F3" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvLargeProfile"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#1A1A2E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivLargeProfilePic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="#5EC7D1"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/photoActionsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cvLargeProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvChangePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Photo"
            android:padding="14dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:textColor="#5EC7D1"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  |  "
            android:textColor="#666680"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvRemovePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove"
            android:textColor="#9E2323"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:padding="12dp"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etProfileUsername"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"

        android:hint="Update Username"
        android:textColor="#000000"
        android:paddingHorizontal="16dp"
        android:inputType="textPersonName"
        app:layout_constraintTop_toBottomOf="@id/photoActionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etProfileNewPassword"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:hint="Set New Password"
        android:textColor="#000000"
        android:paddingHorizontal="16dp"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/etProfileUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnSaveProfileChanges"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:text="Save Changes"
        android:backgroundTint="#2196F3"
        android:textColor="#0F0F1E"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etProfileNewPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnProfileLogout"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="LOGOUT ACCOUNT"
        android:backgroundTint="#F44336"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>