<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E">

    <View
        android:id="@+id/cardBalance"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_margin="16dp"
        android:background="#1A1A2E"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CURRENT ACCOUNT BALANCE"
        android:textColor="#BB86FC"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/cardBalance"
        app:layout_constraintStart_toStartOf="@id/cardBalance"
        android:layout_margin="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R 24,500.00"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/cardBalance"
        app:layout_constraintBottom_toBottomOf="@id/cardBalance"
        app:layout_constraintStart_toStartOf="@id/cardBalance"
        app:layout_constraintEnd_toEndOf="@id/cardBalance"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1A1A2E"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button android:id="@+id/btnNavHome" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Home" android:backgroundTint="@android:color/transparent" android:textColor="#00FFFF"/>
        <Button android:id="@+id/btnNavEntry" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Add Expense" android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnNavGoals" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Budget" android:backgroundTint="@android:color/transparent" android:textColor="#FFFFFF"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>